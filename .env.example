# ── IWC Concepts — Environment Variables ───────────────────────────────────
# For local dev: copy to .env and fill in your values.
# For production: add these in Vercel Dashboard → Project → Settings → Environment Variables.

# ── Database ────────────────────────────────────────────────────────────────
# For Supabase, use the Transaction mode pooler URL (port 6543) — NOT the direct
# connection (port 5432). Designed for serverless; avoids "too many connections".
# Find it: Supabase Dashboard → Project Settings → Database → Connection pooling → Transaction mode
#
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Supabase Auth — server side (no VITE_ prefix) ───────────────────────────
# Used by api/db.js to verify that API callers are logged-in admins.
# Same values as VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY below — just copy them.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase Auth — frontend (VITE_ prefix exposes them to the browser) ──────
# Used by the React app for login / session management.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Paystack (required for paid programs) ───────────────────────────────────
# Secret key from Paystack Dashboard → Settings → API Keys & Webhooks.
# Never expose this in the browser — it is read by api/paystack-init.js and used
# by api/paystack-webhook.js to verify the x-paystack-signature header.
# Webhook URL to register in Paystack (event: charge.success):
#   https://<your-vercel-domain>/api/paystack-webhook
PAYSTACK_SECRET_KEY=sk_live_...

# ── Public site origin (optional) ────────────────────────────────────────────
# Used to build portal/course links in transactional emails (welcome, etc.),
# including those sent from the Paystack webhook which has no browser origin.
PUBLIC_BASE_URL=https://your-domain.vercel.app

# ── Cloudinary (optional) ────────────────────────────────────────────────────
# Image upload signing. If not set, uploads fall back to canvas-compressed base64.
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
