# ── IWC Concepts — Frontend Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values for local development.
# In production, set these in the Vercel Dashboard → Project → Settings → Environment Variables.

# ── Supabase Auth (for admin login) ────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend / API (set in Vercel dashboard, NOT here) ───────────────────────
# DATABASE_URL, SUPABASE_JWT_SECRET, CLOUDINARY_* go on the server side only.
# They are read by api/db.js and api/cloudinary-sign.js at runtime.
# Do NOT prefix them with VITE_ — they must not be exposed to the browser.
