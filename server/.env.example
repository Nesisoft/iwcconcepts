# ── Database ──────────────────────────────────────────────────────────────────
# Any PostgreSQL connection string — local, Supabase, Neon, Railway, your own VPS.
# Swap this one env var to point at a completely different database; no code changes needed.
#
# Local PostgreSQL:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/iwcconcepts
#
# Supabase (use the "Session mode" pooler URL, port 5432):
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Neon / Railway / other managed PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
DATABASE_URL=postgresql://postgres:password@localhost:5432/iwcconcepts

# ── Auth ──────────────────────────────────────────────────────────────────────
# Supabase JWT secret — used to verify admin tokens without any network call.
# Find it: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# If you switch away from Supabase Auth, update the verifyToken() function in index.js.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Image upload signing — moved from Vercel env vars to here.
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your Vercel / Render / Netlify frontend URL.
# Leave * to allow all origins (fine during development).
ALLOWED_ORIGIN=http://localhost:5173

# ── Port ──────────────────────────────────────────────────────────────────────
# Render, Railway, Fly.io etc. set PORT automatically.
# For local dev this defaults to 3001 if not set.
PORT=3001
